{
    "name": "@posthog/ml-mirror-image-scrub",
    "version": "0.0.0",
    "private": true,
    "description": "replay_vision consumer worker that scrubs inlined session-replay images for the ML-training mirror and writes them to S3, using a native ML scrub (NSFW gate + face mosaic + text solid-fill). Standalone package (not registered in pnpm-workspace.yaml) so its deps never reach the root lockfile or the main plugin-server image.",
    "type": "module",
    "scripts": {
        "start": "tsx src/consumer.ts",
        "consume": "tsx src/consumer.ts",
        "test:unit": "jest",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint -c .oxlintrc.json",
        "format": "oxfmt -c .oxfmtrc.json",
        "format:check": "oxfmt -c .oxfmtrc.json --check",
        "produce": "tsx dev/produce.ts",
        "setup": "tsx dev/setup.ts",
        "corpus": "tsx dev/make-corpus.ts",
        "bench": "tsx dev/bench.ts",
        "scale": "tsx dev/scale.ts",
        "verify": "tsx dev/verify.ts",
        "eval": "tsx dev/scrub-eval.ts"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1076.0",
        "@dsnp/parquetjs": "^1.8.7",
        "@tensorflow/tfjs": "^4.22.0",
        "@tensorflow/tfjs-backend-wasm": "^4.22.0",
        "@tensorflow/tfjs-node": "^4.22.0",
        "kafkajs": "^2.2.4",
        "nsfwjs": "^4.2.1",
        "onnxruntime-node": "^1.27.0",
        "prom-client": "^15.1.3",
        "sharp": "^0.34.5",
        "tsx": "^4.19.2"
    },
    "devDependencies": {
        "@babel/core": "^7.26.0",
        "@babel/preset-env": "^7.26.0",
        "@babel/preset-typescript": "^7.26.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^24.0.0",
        "babel-jest": "^29.7.0",
        "jest": "^29.7.0",
        "oxfmt": "^0.35.0",
        "oxlint": "^1.0.0",
        "tesseract.js": "^6.0.1",
        "typescript": "^5.7.2"
    },
    "packageManager": "pnpm@10.29.3",
    "pnpm": {
        "onlyBuiltDependencies": [
            "@tensorflow/tfjs-node",
            "esbuild",
            "onnxruntime-node",
            "sharp"
        ]
    }
}
